{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "unico-export",
  "title": "Unico JSON Export",
  "version": "0.9.0",
  "description": "Design and validate Unico DND pages through compact IR and deterministic import-ready JSON compilation.",
  "license": "MIT",
  "author": {
    "name": "Unico"
  },
  "tags": [
    "export",
    "unico",
    "json",
    "handoff"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ],
    "claudePlugins": [
      {
        "path": "./.claude-plugin/plugin.json"
      }
    ]
  },
  "od": {
    "kind": "skill",
    "taskKind": "new-generation",
    "mode": "prototype",
    "platform": "mobile",
    "scenario": "downstream-export",
    "useCase": {
      "query": {
        "en": "Design a Unico DND page for {{brief}} and export import-ready JSON.",
        "zh-CN": "Design a Unico DND page for {{brief}} and export import-ready JSON."
      }
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "claudePlugins": [
        {
          "path": "./.claude-plugin/plugin.json"
        }
      ],
      "atoms": [
        "handoff"
      ]
    },
    "inputs": [
      {
        "name": "brief",
        "type": "string",
        "required": true,
        "label": "Design brief",
        "default": "mobile landing page"
      }
    ],
    "capabilities": [
      "prompt:inject"
    ]
  }
}
